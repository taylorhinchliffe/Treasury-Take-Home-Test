# AI Provider (required for live verification)
# Primary: XAI_API_KEY for Grok vision (user prefers Grok / xAI and has funded the key)
XAI_API_KEY=your_xai_api_key_here

# Optional fallback (if no XAI key):
# OPENAI_API_KEY=sk-...

# Optional: override the vision model
# VISION_MODEL=grok-4          # default (Grok)
# VISION_MODEL=gpt-4o-mini     # faster/cheaper alternative if you want to switch
# VISION_MODEL=gpt-4o          # higher quality, slower

# Note for Treasury evaluators:
# The deployed Vercel URL uses the key configured in Vercel environment variables.
# You do not need a personal key to test the live site.
# For local runs or your own deploy, add your key above.
