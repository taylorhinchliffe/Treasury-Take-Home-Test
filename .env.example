# AI Provider (required for live verification)
# Preferred for speed: Standard OpenAI key (gpt-4o-mini is fastest for this task)
# Or xAI key (Grok vision) via console.x.ai
OPENAI_API_KEY=sk-...          # Recommended for lowest latency (set this OR XAI below)

# XAI_API_KEY=your_xai_api_key_here   # Alternative - works but can be slightly slower than OpenAI mini

# Optional: override the vision model for speed/accuracy tuning
# VISION_MODEL=gpt-4o-mini     # fastest + cheapest for label text (default)
# VISION_MODEL=grok-4          # if you want to use xAI Grok branding
# VISION_MODEL=gpt-4o          # higher accuracy, slower/more expensive

# Note for Treasury evaluators:
# The deployed Vercel URL uses the key configured in Vercel environment variables.
# You do not need a personal key to test the live site.
# For local runs or your own deploy, add your key above.
